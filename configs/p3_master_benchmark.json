  "predeclared_analyses": [
    "epsilon_utility_curve",
    "visible_messages_vs_ideal_secagg",
    "one_vs_four_vs_eight_public_score_bins",
    "public_only_and_zero_private_signal_separation",
    "global_intra_cross_breakdown",
    "descriptor_sparsity_failure_boundary",
    "client_count_and_release_communication_scaling"
  ],
  "reporting": {
    "seeds": 5,
    "uncertainty": "paired_95pct_t_interval_across_frozen_seeds",
    "test_tuning": false,
    "missing_cell": "report_failure_without_imputation",
    "multiple_comparisons": "Holm correction for confirmatory primary comparisons"
  }
