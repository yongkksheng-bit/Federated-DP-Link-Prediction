    "forbidden": "labeling an unverified nominal epsilon as privacy matched"
  },
  "metrics": {
    "primary": ["global_roc_auc", "cross_roc_auc"],
    "secondary": [
      "intra_roc_auc",
      "global_average_precision",
      "cross_average_precision",
      "paired_gain_over_public_cosine"
